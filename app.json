{
  "expo": {
    "name": "Fantasy",
    "slug": "fantalega-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070c1f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "it.dvdesp.fantatorneo",
      "infoPlist": {
        "NSCameraUsageDescription": "L'app ha bisogno della fotocamera per farti scattare una foto per il profilo e per il logo della squadra.",
        "NSPhotoLibraryUsageDescription": "L'app ha bisogno di accedere alla galleria per permetterti di caricare il logo della tua squadra e la foto profilo."
      }
    },
    "android": {
      "package": "it.dvdesp.fantatorneo",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#070c1f"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "submit": {
        "production": {
          "android": {
            "serviceAccountKeyPath": "./play-store-service-account.json",
            "track": "internal"
          }
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "L'app ha bisogno di accedere alla galleria per permetterti di caricare il logo della tua squadra.",
          "cameraPermission": "L'app ha bisogno della fotocamera per farti scattare una foto per il profilo."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "27719a1e-1c18-49cf-90a3-eea82dc923ba"
      }
    },
    "owner": "dariocast"
  }
}